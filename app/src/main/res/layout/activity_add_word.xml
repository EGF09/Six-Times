<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#ff6750a4"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:contentDescription="Geri Dön" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni Kelime Ekle"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etEngWord"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#ff6750a4"
            android:hint="İngilizce Kelime"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888" />

        <EditText
            android:id="@+id/etTurWord"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#ff6750a4"
            android:hint="Türkçe Karşılığı"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888" />

        <EditText
            android:id="@+id/etSamples"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#ff6750a4"
            android:gravity="top"
            android:hint="Örnek Cümleler"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectImage"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Resim Seç"
            app:icon="@android:drawable/ic_menu_gallery"
            app:cornerRadius="12dp"
            app:backgroundTint="#1E1E1E"
            android:layout_marginBottom="12dp"/>

        <ImageView
            android:id="@+id/ivSelectedImage"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveWord"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Kelimeyi Kaydet"
            app:backgroundTint="#ff6750a4"
            app:cornerRadius="30dp" />

    </LinearLayout>
</ScrollView>